{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@playwright/mcp@latest"],
      "env": {}
    },
    "trustquote": {
      "type": "stdio",
      "command": "D:/projects/TrustQuote/node_modules/.bin/tsx.cmd",
      "args": ["scripts/mcp-server.ts"],
      "cwd": "D:/projects/TrustQuote",
      "env": {}
    }
  }
}
