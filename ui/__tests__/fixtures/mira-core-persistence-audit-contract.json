  "staticValidationRules": [
    {
      "id": "phase-18-baseline-afabea1-pinned",
      "must": "persistence_audit_assessment.baseline_commit and validation_report.baseline_commit are exactly afabea1, the Phase 17 storage-retention baseline."
    },
    {
      "id": "validation-only-no-real-db",
      "must": "Phase 18 emits validation records only; it does not open/create/write a database, run migrations, write files, perform network work, create queues, mutate auth/session/token state, execute locally, send, deploy, trade, commit memory/profile data, export, delete, restore, or store raw content."
    },
    {
      "id": "persistence-assessment-shape-required",
      "must": "Persistence assessment includes baseline ref, storage-retention ref, schema version, dry-run migration status, planned tables/indexes/checksums, accepted/blocked schema elements, audit coverage, and evidence refs."
    },
    {
      "id": "allowed-schema-surfaces-required",
      "must": "Allowed schema surfaces are limited to planned validation-only upload envelopes, sync items, withheld items, tombstones, export manifests, deletion requests, replay watermarks, validation-only intents, audit events, operator status snapshots, and key-reference metadata."
    },
    {
      "id": "forbidden-schema-surfaces-blocked",
      "must": "Raw comms, terminal, OCR/screenshot/browser DOM/cookies, customer private content, secrets/tokens/private keys, side-profile payloads in main, command bodies, and irreversible action execution records are blocked."
    },
    {
      "id": "per-table-minimum-fields-required",
      "must": "Every planned table has profile/device/session/tenant scope, source refs, redaction status, sync eligibility where relevant, payload hash/ref, created_at, retention/expiry where relevant, deletion/tombstone linkage, idempotency/replay keys, schema version, and evidence refs."
    },
    {
      "id": "audit-event-contract-required",
      "must": "Audit events are append-only and include actor, role allowlist, event type allowlist, source ref, scope, decision/status, reason codes, safe before/after hashes, redaction summary, monotonic sequence, retention class, and no raw payload."
    },
    {
      "id": "migration-plan-dry-run-required",
      "must": "Migration plan is dry-run only with deterministic schema hash, reversible plan, rollback plan, no migration executed, no DB opened/created/written, no filesystem output, and no network."
    },
    {
      "id": "deletion-export-audit-rules-required",
      "must": "Tombstone events persist without raw payload; export manifest events are redacted/hashes only; delete request events cannot leak deleted content; backup purge obligations are status records only."
    },
    {
      "id": "profile-isolation-replay-rules-required",
      "must": "Tenant/profile/device/session scoped keys are required; side-profile mismatch fails closed; tombstones beat stale uploads; watermarks are monotonic; duplicate idempotency keys are rejected or diagnosed."
    },
    {
      "id": "capability-boundary-validation-only",
      "must": "Schema/audit validity does not authorize local execution, shell/PTY, Builder/Oracle direct target, Tier 2+, customer-send, deploy, trade, memory/profile commit, model-processing proof, bridge green, raw restore, or server resurrection of deleted state."
    },
    {
      "id": "migration-real-db-gated",
      "must": "Real DB remains blocked until DB engine choice, encryption/key-reference policy, backup retention policy, audit viewer/operator controls, deletion/export API, migration runner safety, schema compatibility tests, disaster recovery plan, and profile isolation integration tests exist."
    },
    {
      "id": "required-gates-and-blockers-present",
      "must": "All required Phase 18 acceptance gate IDs and blocker IDs are present and unique."
    },
    {
      "id": "forbidden-output-strings-absent",
      "must": "Assessment and validation output contain no secret-like strings, raw private content, DB/migration/write claims, raw audit payload claims, bridge/proof overclaims, direct Builder/Oracle target authorization, Tier 2+ authorization claims, or live side-effect claims."
    }
  ],
