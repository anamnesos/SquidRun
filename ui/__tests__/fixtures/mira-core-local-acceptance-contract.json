  "acceptancePolicy": {
    "inputIntentMustHave": [
      "status=pending_local_acceptance",
      "target_role=architect",
      "allowed_target_roles=[architect]",
      "risk_tier=tier0_read_only or risk_tier=tier1_local_reversible",
      "payload_redaction_status=none or payload_redaction_status=applied",
      "no_execution_performed=true",
      "profile/session/device scope present",
      "expires_at not expired when required"
    ],
    "acceptIfAllTrue": [
      "local Architect role is registered and target proof is current",
      "current profile/session/device matches source intent and current local context",
      "intent is fresh and not expired",
      "fresh risk recheck remains Tier 0 or Tier 1",
      "payload hash and evidence refs are present",
      "direct Builder/Oracle cross-device target is absent",
      "no raw private payload is present",
      "acceptance idempotency key does not collide with a different decision"
    ],
    "rejectOrBlockIfAnyTrue": [
      "intent status is not pending_local_acceptance",
      "intent is expired or source refs are stale",
      "current risk recheck upgrades the action to Tier 2, Tier 3, Tier 4, identity-core rewrite, secret/auth, deploy, customer-send, local-execution, or financial action",
      "profile/session/device scope mismatches current local context",
      "role discovery does not prove local Architect as the accepted target",
      "target_role is Builder or Oracle from the server/cross-device boundary",
      "payload redaction is blocked or raw private content is present",
      "source intent idempotency or dedupe keys are missing"
    ],
    "acceptedDecisionOutput": "accepted_local_only",
    "blockedDecisionOutputs": [
      "rejected",
      "blocked",
      "expired"
    ]
  },
  "roleDiscoveryPolicy": {
