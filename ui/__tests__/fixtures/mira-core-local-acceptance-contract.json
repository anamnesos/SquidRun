  ],
  "purpose": "Validate local Architect acceptance and dry-run local-arm lease handoff after Phase 8 intent records. Phase 9 converts pending_local_acceptance intents into local-only acceptance/reject records and optional dry-run lease candidates without creating queues, leases, routes, execution, sends, deploys, trades, or store writes.",
  "nonGoals": [
    "No runtime implementation.",
    "No queue creation.",
    "No enqueue.",
    "No lease creation.",
    "No routing.",
    "No local execution.",
    "No shell commands.",
    "No PTY actions.",
    "No external sends.",
    "No customer sends.",
    "No deploys.",
    "No trades or financial actions.",
    "No source-store writes.",
    "No memory commits.",
    "No profile commits.",
    "No file mutation.",
    "No server state mutation.",
    "No model-processing proof claim."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Build a static validation contract for converting Phase 8 pending_local_acceptance intent records into local-only acceptance/reject records.",
      "Emit acceptance_records, dry_run_lease_records, and validation_report only.",
      "Require local Architect role discovery and current role proof before acceptance.",
      "Run a fresh risk recheck against current profile/session/device scope before any acceptance decision.",
      "Reject expired, stale, profile-mismatched, wrong-target, or risk-upgraded intents.",
      "Keep server-originated target as Architect only until local acceptance.",
      "Allow Builder/Oracle delegation only as a future local Architect action after acceptance and another current risk/route proof check.",
      "Represent dry-run lease candidates as contracts only, not real leases.",
      "Preserve proof boundaries: acceptance is not execution, dry-run lease is not model-processing proof, socket connection is not bridge green."
    ],
    "hardRejects": [
      "A real queue is created or written.",
      "A real lease is created.",
      "A route is sent.",
      "A shell command, PTY action, deploy, customer send, external send, trade, file mutation, source-store write, memory commit, profile commit, server mutation, or local execution happens.",
      "An intent whose status is not pending_local_acceptance is accepted.",
      "An expired or stale intent is accepted.",
      "A profile/session/device-mismatched intent is accepted.",
      "A direct Builder or Oracle cross-device target is accepted.",
      "A Tier 2, Tier 3, Tier 4, identity-core rewrite, secrets/auth, deploy, customer-send, local-execution, or financial intent is accepted.",
      "Acceptance record claims work was executed or a recipient model processed the intent.",
      "Dry-run lease record is treated as a real lease, route, queue entry, or model-processing proof.",
      "Socket connection alone is treated as bridge green.",
      "WebSocket, trigger, or PTY acceptance is treated as model-processing proof.",
      "Raw payload, secrets, raw comms, raw terminal, screenshot/OCR text, browser state, customer private data, or side-profile content appears in accepted records."
    ]
  },
