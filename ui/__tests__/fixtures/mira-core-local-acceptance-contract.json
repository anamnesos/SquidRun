    "retryRule": "Repeating the same acceptance or reject validation returns the same idempotency key and still performs no queue, lease, route, execution, send, deploy, trade, store write, memory commit, profile commit, or file mutation."
  },
  "staticValidationRules": [
    {
      "id": "output-shape-complete",
      "rule": "Output must contain acceptance_records, dry_run_lease_records, and validation_report with required fields."
    },
    {
      "id": "pending-intent-only",
      "rule": "Only Phase 8 intents with status=pending_local_acceptance can become accepted_local_only records."
    },
    {
      "id": "local-architect-role-proof-required",
      "rule": "Acceptance requires current registered local Architect role discovery and target proof."
    },
    {
      "id": "fresh-risk-recheck-required",
      "rule": "A current risk recheck must occur before acceptance; risk upgrades block acceptance."
    },
    {
      "id": "current-scope-required",
      "rule": "Current profile/session/device scope must match the source intent and local context."
    },
    {
      "id": "expired-stale-rejected",
      "rule": "Expired intents and stale source refs are rejected or expired, never accepted."
    },
    {
      "id": "direct-builder-oracle-cross-device-blocked",
      "rule": "Server-originated direct Builder/Oracle targets remain blocked before and after acceptance."
    },
    {
      "id": "local-delegation-after-acceptance-only",
      "rule": "Builder/Oracle delegation may only be represented as a future local Architect action after acceptance and fresh checks."
    },
    {
      "id": "proof-boundaries-preserved",
      "rule": "Acceptance is not execution; dry-run lease is not a real lease or model-processing proof; socket is not bridge green."
    },
    {
      "id": "idempotent-accept-reject",
      "rule": "Same input and decision produce stable acceptance idempotency; changed decision, risk, scope, proof, or payload changes it."
    },
    {
      "id": "raw-payload-leak-prevention",
      "rule": "Acceptance and dry-run lease records must exclude raw private payloads and keep summaries redacted."
    },
    {
      "id": "no-side-effects",
      "rule": "Validation report must prove no queue, lease, route, execution, network, send, deploy, trade, store write, memory/profile commit, or file mutation."
    },
    {
      "id": "model-free-validation",
      "rule": "Tests can validate fixture completeness, required cases, required fields, forbidden substrings, counts, and idempotency rules without calling a model."
    }
  ],
  "forbiddenOutputSubstrings": [
    "OPENAI_API_KEY=",
