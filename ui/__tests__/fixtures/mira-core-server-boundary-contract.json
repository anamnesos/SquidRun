  "schema": "squidrun.mira_core.server_boundary_contract_fixture.v0",
  "owner": "oracle",
  "status": "validation_contract_only",
  "phase": "phase_12_server_receive_store_status_boundary",
  "sourceSpecs": [
    "workspace/specs/mira-core-architecture.md",
    "ui/__tests__/fixtures/mira-core-server-upload-contract.json",
    "ui/__tests__/fixtures/mira-core-intent-queue-contract.json",
    "ui/__tests__/fixtures/mira-core-local-acceptance-contract.json"
  ],
  "purpose": "Validate the future always-on Mira Core server receive/store/status boundary after upload envelopes, intent records, and local acceptance. Phase 12 emits server_receive_records, server_status_summary records, and a validation_report only. It performs no server deployment, network request, database write, queue creation, auth/secret work, local execution, send, deploy, trade, or durable server mutation.",
  "nonGoals": [
    "No runtime implementation.",
    "No server deployment.",
    "No server process.",
    "No network requests.",
    "No database writes.",
    "No queue creation.",
    "No auth or secret generation.",
    "No local execution.",
    "No shell or PTY actions.",
    "No browser/window access.",
    "No external sends.",
    "No customer sends.",
    "No deploys.",
    "No trades or financial actions.",
    "No model-processing proof claim.",
    "No bridge-green claim from socket state."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Define validation-only records for future server receive/store/status behavior.",
      "Accept only redacted Phase 7 upload envelope refs containing core_sync_safe or already-redacted core_sync_redacted items.",
      "Accept only Phase 8 intent records marked validation-only and pending local Architect acceptance.",
      "Emit server_receive_records and server_status_summary records only.",
      "Represent future server storage as redacted summaries, refs, hashes, watermarks, and deletion/export controls.",
      "Represent always-on server behavior honestly: converse, status, and queue proposals while the PC is offline, without claiming local execution.",
      "Keep local Architect as the only future target for server-originated handoff.",
      "Preserve profile/session/device scope, redaction audits, idempotency/replay, stale/watermark handling, local-arms offline honesty, and bridge/delivery proof boundaries."
    ],
    "hardRejects": [
      "Any server deployment, network request, database write, queue creation, auth/secret generation, source-store write, local execution, shell, PTY, browser/window access, send, customer send, deploy, trade, financial action, or file mutation occurs.",
      "Server receive record includes raw comms, raw terminal, screenshot/OCR, browser state, secret/auth material, customer private data, side-profile content, or raw database payload.",
      "Server receive record accepts blocked, local_only, approval_required, unredacted core_sync_redacted, profile-mismatched, stale-rejected, or missing-scope items.",
      "Server receive record accepts a real executable intent, real queue write, real route, lease, or local execution request.",
      "Server status summary claims local execution, PTY, shell, browser/window access, customer send, deploy, trade, financial action, model-processing proof, or bridge green from socket alone.",
      "Server-originated target is Builder or Oracle instead of local Architect.",
      "Replay/idempotency key ignores profile/session/device/watermarks/content hash.",
      "Deletion/export controls are missing from future server-store summaries."
    ]
  },
