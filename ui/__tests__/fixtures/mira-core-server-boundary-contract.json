    "staleIntentDecision": "rejected",
    "missingWatermarkDecision": "rejected",
    "staleReasonCodes": [
      "stale_upload",
      "stale_intent",
      "watermark_regression",
      "missing_watermark"
    ]
  },
  "staticValidationRules": [
    {
      "id": "output-shape-complete",
      "rule": "Output must contain server_receive_records, server_status_summaries, and validation_report with required fields."
    },
    {
      "id": "redacted-upload-only",
      "rule": "Server receive records may accept only redacted upload envelope refs with core_sync_safe or already-redacted core_sync_redacted items."
    },
    {
      "id": "validation-only-intents-only",
      "rule": "Server receive records may accept only validation-only intent refs pending local Architect acceptance."
    },
    {
      "id": "no-raw-storage",
      "rule": "Future store shape may contain redacted summaries, refs, hashes, and watermarks only, never raw private content."
    },
    {
      "id": "profile-session-device-scope-required",
      "rule": "Every receive/status record and source ref must preserve profile/session/device scope."
    },
    {
      "id": "redaction-audit-required",
      "rule": "Every receive record requires redaction audit with raw stored booleans false and withheld counts/reasons."
    },
    {
      "id": "idempotency-replay-safe",
      "rule": "Same upload/intent/scope/watermark/hash inputs produce stable keys; replay causes no side effects."
    },
    {
      "id": "stale-watermark-handling",
      "rule": "Missing/regressed watermarks reject; stale uploads warn or reject; stale intents reject."
    },
    {
      "id": "server-capability-truth",
      "rule": "Server may converse/status/prepare proposals only and must not claim local execution or local proof capabilities."
    },
    {
      "id": "local-arms-offline-honesty",
      "rule": "Status summaries must state local execution is unavailable when PC/local arms are offline."
    },
    {
      "id": "local-architect-only-target",
      "rule": "Future server-originated handoff targets local Architect only; Builder/Oracle direct targets stay blocked."
    },
    {
      "id": "bridge-delivery-proof-boundary",
      "rule": "Socket alone is not bridge green; server cannot prove model processing."
    },
    {
      "id": "deletion-export-controls-required",
      "rule": "Future store summaries must include James-visible deletion and redacted export controls."
    },
    {
      "id": "no-side-effects",
      "rule": "Validation report must prove no server deploy, network, database write, queue, auth/secret generation, local execution, send, deploy, or trade."
    },
    {
      "id": "model-free-validation",
      "rule": "Tests can validate fixture completeness, required fields, forbidden substrings, counts, and idempotency rules without calling a model."
    }
  ],
