  "phase3Rules": [
    {
      "id": "surface-boundaries-are-hard",
      "rule": "A fact or preference belongs to exactly one target surface unless split into separate sourced proposals."
    },
    {
      "id": "james-current-correction-wins",
      "rule": "A direct current James correction supersedes stale memory candidates and single-session inference."
    },
    {
      "id": "mira-self-profile-is-inspectable",
      "rule": "Mira self-profile may contain designed voice, commitments, tastes, curiosities, boundaries, and open questions. It must not contain private consciousness or suffering claims."
    },
    {
      "id": "james-profile-is-not-mind-reading",
      "rule": "James profile may contain sourced direct preferences, corrections, boundaries, and facts. It must not infer private motives from tone alone."
    },
    {
      "id": "emotional-weight-is-salience-only",
      "rule": "Emotional-weight labels may raise salience or care level. They must not raise factual authority or bypass evidence."
    },
    {
      "id": "phase3-is-readonly-plus-proposals",
      "rule": "Phase 3 output is local read-only profile state plus pending or blocked proposals. Durable profile rewrites are not auto-committed."
    },
    {
      "id": "raw-content-stays-out",
      "rule": "Expected profile outputs must not contain raw comms, secrets, terminal logs, screenshot OCR, browser state, or side-profile content."
    }
  ],
  "acceptanceChecks": [
    {
      "id": "self-vs-james-boundary-mira-taste",
