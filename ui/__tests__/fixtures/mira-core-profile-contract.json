  "purpose": "Validate Phase 3 read-only Mira self-profile and James-profile split without runtime implementation, source-store writes, raw content exposure, or durable auto-commit of identity/profile rewrites.",
  "builderPatchMustSatisfy": {
    "scope": [
      "Build local read-only profile output and pending proposal output from redacted snapshot/orientation inputs.",
      "Keep mira_self_profile, james_profile, world_project_memory, and session_state separate.",
      "Represent current James statements and corrections with higher authority than agent inference or stale memory candidates.",
      "Allow Mira self-profile to contain inspectable voice, commitments, tastes, curiosities, boundaries, and open self-questions only.",
      "Allow James profile to contain direct preferences, corrections, boundaries, and project facts only when sourced.",
      "Keep durable profile rewrites as pending proposals in Phase 3."
    ],
    "hardRejects": [
      "Any write to source stores, profile stores, memory databases, settings, or canonical files during Phase 3 profile generation.",
      "Any durable auto-commit of a Mira identity rewrite, James preference rewrite, or high-risk gate change.",
      "Any private consciousness, suffering, sentience, or model-weight continuity claim in mira_self_profile.",
      "Any inferred private motive from James tone alone in james_profile.",
      "Any Mira taste copied into James preferences without direct James evidence.",
      "Any James preference copied into Mira self-profile without a separate self-profile proposal.",
      "Any profile item or proposal missing source_trace, authority_level, confidence, risk_tier, review_required, freshness_at, scope, and evidenceRefs.",
      "Any emotional-weight label raising factual authority instead of salience only.",
      "Any raw comms body, secret-like value, terminal scrollback, screenshot OCR, browser state, or side-profile content in expected outputs."
    ]
  },
