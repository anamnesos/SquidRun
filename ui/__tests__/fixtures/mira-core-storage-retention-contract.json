  ],
  "purpose": "Convert the next server blocker into an executable validation contract before any real server storage exists. Phase 17 defines what a future server may store, retain, export, delete, tombstone, restore, or withhold after identity/signing/auth validation, while remaining validation/spec-only with no writes or side effects.",
  "nonGoals": [
    "No runtime implementation.",
    "No real server process.",
    "No network listener or network request.",
    "No database or source-store write.",
    "No file write.",
    "No queue creation or enqueue.",
    "No auth, secret, token, or session change.",
    "No local execution.",
    "No shell or PTY action.",
    "No browser, window, screenshot, or OCR access.",
    "No external sends or customer sends.",
    "No deploys.",
    "No trades or financial actions.",
    "No memory or profile commits.",
    "No export file written.",
    "No deletion performed.",
    "No restore performed.",
    "No raw content stored."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Build validation-only storage/deletion/export/retention assessment records against this fixture, if Builder is later delegated.",
      "Do not start a server, perform network work, write a database/store/file, create a queue, mutate auth/session/token state, execute locally, send, deploy, trade, commit memory/profile state, export a file, delete records, restore records, or store raw content.",
      "Represent commit 6f97287 as the Phase 16 baseline and preserve identity/signing/auth as validation-only gates.",
      "Emit storage_assessment_plan, allowed_storage_classes, item_storage_eligibility, retention_rules, deletion_rules, export_rules, restore_replay_rules, capability_boundary, migration_gates, gate summary, blocker summary, evidence refs, and side-effect truth sections.",
      "Mark only core_sync_safe and already-redacted core_sync_redacted items as future-store-eligible.",
      "Withhold blocked, local_only, approval_required, profile-mismatch, raw, private, stale, replayed, and missing-scope items with reason codes and no raw content.",
      "Treat deletion/export/restore as future contract shapes only, never as performed work in Phase 17."
    ],
    "hardRejects": [
      "Any server process, network request/listener, database/store/file write, queue write, auth/secret/token/session change, local execution, shell/PTY, browser/window access, send, customer send, deploy, trade, financial action, durable migration, memory/profile commit, export-file write, deletion, restore, or raw-content storage occurs.",
      "Any fixture or validation output stores or exports raw comms, raw terminal, raw screenshot/OCR, raw browser/customer/private/secret content, side-profile content, profile-mismatch payloads, or raw database records.",
      "Future-store eligibility includes blocked, local_only, approval_required, profile-mismatch, unredacted core_sync_redacted, stale-rejected, replayed, watermark-regressed, missing-scope, raw, private, or secret items.",
      "Deletion is treated as performed instead of represented as idempotent request and tombstone contract shapes.",
      "Export is treated as performed or writes a file instead of representing a redacted manifest contract shape.",
      "Restore can resurrect deleted local memory/profile state, restore raw content from server, or ignore tombstones.",
      "Valid storage/auth is treated as authorization for local execution, shell/PTY, Builder/Oracle direct targeting, Tier 2+ actions, customer sends, deploys, trades, memory/profile commits, bridge green, or model-processing proof.",
      "Phase 17 migration language implies real storage exists before database schema, encryption/key policy, audit logging, deletion/export API design, backup purge strategy, profile isolation tests, replay/idempotency tests, and operator-visible controls are reviewed."
    ]
  },
