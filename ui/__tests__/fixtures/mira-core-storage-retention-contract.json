  "staticValidationRules": [
    {
      "id": "phase-17-baseline-6f97287-pinned",
      "must": "storage_retention_assessment.baseline_commit and validation_report.baseline_commit are exactly 6f97287, the Phase 16 auth-binding baseline."
    },
    {
      "id": "validation-only-no-real-storage",
      "must": "Phase 17 emits validation records only; it does not start a server, perform network work, write databases/stores/files, create queues, mutate auth/session/token state, execute locally, send, deploy, trade, commit memory/profile data, export files, delete, restore, or store raw content."
    },
    {
      "id": "storage-assessment-plan-shape-required",
      "must": "Storage assessment plan includes baseline ref, authenticated receive ref, upload envelope ref, profile/device/session scope, tenant boundary, item counts, decision/status, and evidence refs."
    },
    {
      "id": "allowed-storage-classes-required",
      "must": "Allowed storage classes are limited to metadata_only, redacted_payload, hash_reference, encrypted_future_placeholder, tombstone_only, and export_manifest_only."
    },
    {
      "id": "raw-private-storage-blocked",
      "must": "Raw comms, terminal, OCR, browser, customer/private, secret, profile-mismatch, side-profile, and raw database content are blocked."
    },
