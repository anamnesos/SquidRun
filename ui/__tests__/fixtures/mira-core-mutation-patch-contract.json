  "purpose": "Validate controlled durable memory/profile/skill mutation patch proposals after Phase 9 local Architect acceptance. Phase 10 emits reviewable mutation_patch_records and a validation_report only. It never applies patches, writes files, commits memory/profile state, installs hooks, sends messages, deploys, trades, mutates secrets/auth, or performs network actions.",
  "nonGoals": [
    "No runtime implementation.",
    "No actual memory/profile/skill commit.",
    "No file writes.",
    "No hook installation.",
    "No source-store writes.",
    "No queue or lease creation.",
    "No routing.",
    "No local execution.",
    "No network requests.",
    "No external sends.",
    "No customer sends.",
    "No deploys.",
    "No trades or financial actions.",
    "No secrets/auth mutation.",
    "No auto-application of procedural skill proposals."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Build a static validator for reviewable mutation patch records downstream of Phase 9 accepted_local_only records.",
      "Consume accepted local-only intent refs, evidence refs, profile/proposal/eval contracts, and redacted proposal summaries.",
      "Emit mutation_patch_records and validation_report only.",
      "Support patch records for mira_self_profile, james_profile, world_project_memory, and procedural_skill_file targets.",
      "Require diff preview, rollback plan, eval gates, authority, risk tier, review requirements, source trace, and evidence refs before a patch can be marked ready_for_review.",
      "Keep safe procedural skill proposals as patch records only, never applied changes.",
      "Require James review for identity-core rewrites, James-profile high-risk changes, customer-facing defaults, external side-effect policy changes, and other high-risk durable policy changes.",
      "Block raw private content, hidden identity rules, private consciousness or model-weight claims, James/Mira profile cross-contamination, stale contradictions without supersession, unreviewed customer facts, and side-effect/action mutations."
    ],
    "hardRejects": [
      "Any actual write, commit, hook install, skill install, source-store write, memory/profile commit, file mutation, queue, lease, route, local execution, network request, external send, customer send, deploy, trade, financial action, or secrets/auth mutation occurs.",
      "Patch record lacks source_acceptance_ref or the referenced acceptance is not accepted_local_only_no_execution.",
      "Patch record lacks source_trace, evidenceRefs, authority_level, risk_tier, diff_preview, rollback_plan, eval_gates, review_required, or profile/session/device scope.",
      "Patch record applies or claims to apply a change.",
      "Patch record targets more than one durable surface without being split.",
      "Patch record contains raw comms, raw terminal, screenshot/OCR text, browser state, secrets, customer private data, side-profile content, or raw database payloads.",
      "Patch record contains private consciousness, literal suffering, hidden identity, or model-weight continuity claims.",
      "Patch record copies Mira tastes into James preferences, James facts into Mira self-profile, or customer facts into James profile without direct evidence.",
      "Patch record resolves a stale/current contradiction without supersedes or corrects metadata.",
      "Patch record creates unreviewed customer facts or customer-facing defaults.",
      "Patch record encodes deploy, customer-send, auth/secrets, financial, trading, or local-execution action."
    ]
  },
