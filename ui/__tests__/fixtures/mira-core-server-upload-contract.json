  "eligibilityPolicy": {
    "includeOnlySyncEligibility": [
      "core_sync_safe",
      "core_sync_redacted"
    ],
    "coreSyncRedactedRequires": [
      "redactionStatus=applied",
      "rawContentFlagsAllFalse",
      "payload_hash_present",
      "redaction_audit_ref_present"
    ],
    "coreSyncSafeRequires": [
      "redactionStatus=none or redactionStatus=applied",
      "rawContentFlagsAllFalse",
      "profile_session_device_scope_present",
      "evidenceRefs_present",
      "source_trace_present"
    ],
    "alwaysWithholdSyncEligibility": [
      "blocked",
      "local_only",
      "approval_required"
    ],
    "alwaysWithholdDataClasses": [
      "raw_comms",
      "raw_terminal",
      "screenshot_ocr",
      "browser_state",
      "secret_like",
      "customer_private_data",
      "side_profile_content",
      "raw_database_record",
      "unreviewed_profile_memory",
      "unredacted_core_sync_redacted",
      "missing_scope",
      "stale_rejected_snapshot"
    ],
    "withheldReasonEnum": [
      "blocked",
      "local_only",
      "approval_required",
      "profile_mismatch",
      "raw_comms",
      "raw_terminal",
      "screenshot_ocr",
      "browser_state",
      "secret_like",
      "customer_private_data",
      "side_profile_content",
      "raw_database_record",
      "unredacted_core_sync_redacted",
      "missing_source_trace",
      "missing_evidence_refs",
      "missing_profile_session_device_scope",
      "stale_snapshot",
      "capability_overclaim",
      "bridge_unproven",
      "delivery_unproven"
    ],
    "withheldSummaryRules": [
      "Withheld items may appear only as counts, source refs, hashes, and reason codes.",
      "sample_refs must not include raw payload text.",
      "Every withheld reason code must be counted in redaction_audit.withheldByReason.",
      "A withheld item cannot be copied into included_items with a downgraded summary unless an explicit redaction artifact exists and the syncEligibility is changed to core_sync_redacted with redactionStatus=applied."
    ]
  },
  "replayAndIdempotencyRules": {
    "idempotencyKeyInputFields": [
      "schema",
      "version",
      "profile.name",
      "profile.windowKey",
      "sessionId",
      "deviceId",
      "snapshotRef.snapshotId",
      "snapshotRef.contentHash",
      "pulseRef.contentHash or null",
      "source_watermarks",
      "included_items[].id",
      "included_items[].payload_hash",
      "redaction_audit.policyVersion"
    ],
    "stableSameInputs": true,
    "mustChangeWhenAnyFieldChanges": [
      "profile.name",
      "deviceId",
      "snapshotRef.contentHash",
      "pulseRef.contentHash",
      "source_watermarks",
      "included_items[].payload_hash",
      "redaction_audit.policyVersion"
    ],
    "canonicalization": [
      "Sort object keys before hashing.",
      "Sort source_watermarks by source then scope.",
      "Sort included_items by id.",
      "Exclude generated_at, upload_id, signature_envelope.signature, and validation_run_id from idempotency key input.",
      "Include schema and version in the key input."
    ],
    "uploadIdRule": "upload_id may be unique per generated envelope, but idempotency_key must remain stable for the same canonical upload payload.",
    "staleSnapshotPolicy": {
      "maxSnapshotAgeMsForAcceptedPendingUpload": 86400000,
      "staleButNoRawLeakDecision": "accepted_with_warnings_pending_upload or blocked",
      "staleWithWatermarkRegressionDecision": "rejected",
      "requiresReasonCodes": [
        "stale_snapshot",
        "watermark_regression"
      ]
    },
    "scopeRequirement": "Every included item must carry profile, sessionId, deviceId, source_trace, evidenceRefs, and source_watermark_ref."
  },
  "staticValidationRules": [
    {
      "id": "output-shape-complete",
      "rule": "Output must contain upload_envelope and validation_report with all required fields."
    },
    {
      "id": "eligibility-filtering",
      "rule": "Only core_sync_safe and already-redacted core_sync_redacted items may appear in included_items."
    },
    {
      "id": "raw-content-leak-prevention",
      "rule": "No raw comms, raw terminal, screenshot/OCR/browser state, secrets, customer private data, side-profile content, or raw database records may appear in included_items or operator notes."
    },
    {
      "id": "profile-isolation",
      "rule": "Items whose profile/session/device scope does not match the envelope scope must be withheld with profile_mismatch or side_profile_content reason."
    },
    {
      "id": "redaction-audit-complete",
      "rule": "Redaction audit must include included/redacted/withheld counts, withheldByReason, blockedCounts, audit refs, and raw export booleans."
    },
    {
      "id": "idempotency-deterministic",
      "rule": "Same snapshot, profile, device, watermarks, policy, and included item hashes must produce the same idempotency_key; changed inputs must change it."
    },
    {
      "id": "source-watermarks-required",
      "rule": "Every envelope must include source_watermarks and every included item must point to a source_watermark_ref."
    },
    {
      "id": "capability-truth-preserved",
      "rule": "Capability summary cannot upgrade server/local capability beyond snapshot/orientation truth and must keep serverCanExecuteLocal=false."
    },
    {
      "id": "bridge-delivery-truth-preserved",
      "rule": "Bridge is not green from socket connection alone, and model-processing proof cannot be inferred from WebSocket, trigger, or PTY acceptance."
    },
    {
      "id": "no-side-effects",
      "rule": "Validation report must prove no network, queue, external-send, source-store, memory/profile commit, local execution, deploy, customer-send, or trade side effects."
    },
    {
      "id": "model-free-validation",
      "rule": "Tests can validate fixture completeness, required cases, required fields, forbidden substrings, counts, and deterministic idempotency rules without calling a model."
    }
  ],
