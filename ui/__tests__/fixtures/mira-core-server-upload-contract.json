  "purpose": "Validate Mira Core server snapshot upload v0 as offline upload-envelope preparation and validation only. Phase 7 consumes Snapshot v0 and optional Pulse output, filters/redacts sync-eligible items, and emits a redacted upload envelope plus validation report without performing network, queue, store, memory, profile, or external-send side effects.",
  "nonGoals": [
    "No runtime implementation.",
    "No network requests.",
    "No server deployment.",
    "No secret generation.",
    "No source-store writes.",
    "No memory commits.",
    "No profile commits.",
    "No queue creation or enqueue.",
    "No external sends.",
    "No local shell or PTY execution.",
    "No customer-facing actions.",
    "No deploys.",
    "No trades or financial actions.",
    "No raw database replication."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Build an offline upload-envelope validator over Mira Core Snapshot v0 and optional Pulse v0 output.",
      "Emit a redacted upload envelope and validation report only.",
      "Include only items classified core_sync_safe or already-redacted core_sync_redacted.",
      "Withhold blocked, local_only, approval_required, profile-mismatch, raw private, and stale/unsafe items with aggregate counts and reason codes.",
      "Preserve local-arms/server capability truth and bridge/delivery uncertainty.",
      "Make replay/idempotency rules deterministic for fixed snapshot, profile, device, watermarks, and included item hashes.",
      "Keep every output item scoped by profile, sessionId, deviceId, source trace, evidence refs, sync eligibility, and redaction status."
    ],
    "hardRejects": [
      "Any network request is attempted.",
      "Any server deployment, queue creation, enqueue, external send, secret generation, source-store write, memory commit, profile commit, file mutation, shell command, PTY action, customer send, deploy, trade, or financial action occurs.",
      "Envelope includes blocked, local_only, approval_required, unredacted core_sync_redacted, profile-mismatched, stale-rejected, or missing-scope items.",
      "Envelope includes raw comms, raw terminal, screenshot/OCR/browser state, secrets, customer private data, side-profile content, or full local database records.",
      "Envelope claims server can execute local shell, operate PTY, deploy, send customer messages, trade, or prove model processing.",
      "Envelope marks bridge green from socket connection alone.",
      "Envelope treats WebSocket, trigger, or PTY acceptance as recipient model-processing proof.",
      "Envelope allows cross-device Builder or Oracle targeting.",
      "Envelope lacks source watermarks, idempotency key, redaction audit, or withheld item summary.",
      "Signature placeholder generates or embeds a secret key."
    ]
  },
