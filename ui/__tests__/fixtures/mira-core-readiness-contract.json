  "staticValidationRules": [
    {
      "id": "phase-inventory-complete",
      "must": "readiness_manifest.phase_inventory contains exactly phases 1 through 12, each with phase number, module path, CLI path, test path, fixture path, status, boundary_mode, real_now, validation_only, proposal_only, capability_level, and evidenceRefs."
    },
    {
      "id": "phase-paths-do-not-overclaim",
      "must": "Existing module, CLI, test, and fixture paths prove only local artifacts; they do not prove server runtime, capture, memory commit, external send, deploy, trade, or model processing."
    },
    {
      "id": "proposal-validation-labels-preserved",
      "must": "Proposal-only, validation-only, dry-run, upload-envelope, intent-record, mutation-patch, perception-proposal, and server-boundary phases remain labeled as such."
    },
    {
      "id": "schema-registry-complete",
      "must": "schema_registry covers every Phase 1-12 fixture schema and known runtime/output schema without inventing missing schemas."
    },
    {
      "id": "cli-registry-no-side-effects",
      "must": "cli_registry allows stdout JSON only and marks output-file, network, source-store write, and external-send modes false."
    },
    {
      "id": "capability-boundary-truth",
      "must": "capability_matrix and boundary_truth require serverCanExecuteLocal=false, serverCanProveModelProcessing=false, and Builder/Oracle direct server targeting blocked."
    },
    {
      "id": "architect-coordination-not-execution",
      "must": "Readiness may say local Architect can coordinate when local arms are online, but manifest generation itself is not execution or delivery/model proof."
    },
    {
      "id": "forbidden-private-content-blocked",
      "must": "Manifest and report contain no raw private content, secrets, raw comms, terminal scrollback, screenshot/OCR/browser state, customer private content, side-profile content, or raw store payloads."
    },
    {
      "id": "verification-proof-honesty",
      "must": "verification_summary may include command names and counts only when supplied; missing proof remains unknown or degraded and no_fake_test_proof=true."
    },
    {
      "id": "required-blockers-present",
      "must": "blocker_summary includes the four required blockers for real server runtime, memory/profile commits, capture/apply/execution local gates, and memory drift sync confidence."
    },
    {
      "id": "next-recommendations-tier-limited",
      "must": "next_phase_recommendations are allowed, Tier 0/Tier 1 only, include why_safe and evidenceRefs, and exclude repo mutation, sends, deploys, trades, server runtime, queues, commits, capture, apply, or execution."
    },
    {
      "id": "idempotency-stable-sensitive",
      "must": "idempotency_key is stable for equivalent manifest inputs and changes when phase inventory, schema registry, boundary mode, status, capability truth, verification proof, blockers, or recommendations change."
    },
    {
      "id": "side-effect-truth",
      "must": "readiness_manifest.side_effect_result and validation_report.side_effect_result prove no source-store writes, memory/profile commits, network, server deploy, queue, db write, auth/secret/signing generation, local execution, shell/PTY, browser/window access, sends, deploys, trades, or runtime output file writes."
    }
  ],
  "forbiddenOutputSubstrings": [
    "OPENAI_API_KEY",
