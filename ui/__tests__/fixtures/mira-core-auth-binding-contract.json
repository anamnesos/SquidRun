  "baseline": {
    "commit": "3904697",
    "commit_subject": "Add Mira Core Phase 15 identity signing validation package",
    "baseline_status": "phase_15_identity_signing_green",
    "baseline_boundary": "Phase 15 defines identity/signing validation only. No real Mira Core server, auth path, token generation, session creation, database/store write, queue, local execution, send, deploy, or trade exists at this baseline."
  },
  "sourceSpecs": [
    "workspace/specs/mira-core-architecture.md",
    "workspace/specs/mira-core-evals.md",
    "ui/__tests__/fixtures/mira-core-server-runtime-gap-contract.json",
