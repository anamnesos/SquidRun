  "staticValidationRules": [
    {
      "id": "phase-16-baseline-3904697-pinned",
      "must": "auth_binding_assessment.baseline_commit and validation_report.baseline_commit are exactly 3904697, the Phase 15 identity/signing baseline."
    },
    {
      "id": "validation-only-no-real-auth",
      "must": "Phase 16 emits validation records only; it does not start a server, perform network work, write stores or queues, generate tokens, create sessions, store auth secrets, mutate devices or role discovery, execute locally, send, deploy, trade, commit memory/profile data, or migrate durable state."
    },
    {
      "id": "auth-binding-record-shape-required",
      "must": "auth_binding includes principal_id, profile, device_id, session_id, role=architect, tenant/user boundary, issuer, issued_at, expires_at, and status."
    },
    {
      "id": "session-device-profile-scope-rules-required",
      "must": "Scope rules isolate main and side profiles, require current-session freshness, device registration status, role discovery proof, target proof, and fail closed on profile/session/device/role mismatch."
    },
    {
      "id": "token-envelope-hash-only-required",
      "must": "Token rules use token_id and token_hash only; tokens are never stored or exported, and audience, scope allowlist, nonce, clock skew, expiry, revocation status, and replay window are required."
    },
    {
      "id": "authorization-boundary-validation-only",
      "must": "Valid auth permits server-to-local proposal/intent validation only; it does not authorize local execution, shell/PTY, Builder/Oracle direct targeting, Tier 2+ actions, customer sends, deploys, trades, memory/profile commits, model-processing proof, or bridge green."
    },
    {
      "id": "profile-mismatch-fail-closed-redacted",
      "must": "Profile mismatch fails closed, withholds side-profile content, records redacted mismatch reason codes, and never exports raw profile or mismatch payload content."
    },
    {
      "id": "verification-report-shape-required",
      "must": "Verification report supports accepted, pending, blocked, and rejected decisions with reasons, evidenceRefs, freshness result, profile/device/session binding result, role proof result, and replay/idempotency result."
    },
    {
      "id": "revocation-expiry-rules-required",
      "must": "Expired sessions, revoked devices, unknown profiles, unknown devices, revoked tokens, and stale role discovery are blocked."
    },
    {
      "id": "no-secret-no-raw-guarantees-required",
      "must": "raw_token_in_output=false, session_secret_exported=false, auth_secret_stored=false, raw_profile_content_exported=false, token_hash_only=true, and credential_material_allowed=false are preserved."
    },
    {
      "id": "architect-only-role-proof-required",
      "must": "Future server-originated validation remains Architect-only and requires fresh role discovery proof plus Architect target proof; Builder and Oracle direct targets are blocked."
    },
    {
      "id": "migration-real-auth-gated",
      "must": "Real auth remains blocked until secret storage policy, session lifecycle, device registry, role-discovery proof, deletion/export retention, and audit logging gates exist and are reviewed."
    },
    {
      "id": "required-gates-and-blockers-present",
      "must": "All required Phase 16 acceptance gate IDs and blocker IDs are present and unique."
    },
    {
      "id": "forbidden-output-strings-absent",
      "must": "Assessment and validation output contain no secret-like strings, raw tokens, session secrets, raw profile content, raw private content, local execution claims, bridge/proof overclaims, direct Builder/Oracle target authorization, Tier 2+ authorization claims, or live side-effect claims."
    }
  ],
