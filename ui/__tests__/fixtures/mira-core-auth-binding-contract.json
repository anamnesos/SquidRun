    "ui/__tests__/fixtures/mira-core-local-acceptance-contract.json",
    "ui/__tests__/fixtures/mira-core-server-boundary-contract.json"
  ],
  "purpose": "Convert the Phase 14 auth/session/device/profile-binding blocker into an executable validation contract before any real server or auth work exists. Phase 16 specifies record shapes, required literals, scope rules, token-hash-only envelope constraints, fail-closed profile mismatch behavior, verification report shape, revocation and expiry handling, no-secret/no-raw guarantees, and migration gates for future real auth.",
  "nonGoals": [
    "No runtime implementation.",
    "No real server process.",
    "No network listener or network request.",
    "No database, source-store, or durable memory write.",
    "No queue creation or enqueue.",
    "No auth, token, credential, secret, or session change.",
    "No real token generation.",
    "No session creation.",
    "No device registration mutation.",
    "No role discovery mutation.",
    "No local execution.",
    "No shell or PTY action.",
    "No browser, window, screenshot, or OCR access.",
    "No external sends or customer sends.",
    "No deploys.",
    "No trades or financial actions.",
    "No memory/profile commits.",
    "No claim that valid auth authorizes local execution.",
    "No claim that valid auth proves model processing.",
    "No claim that valid auth proves bridge green.",
    "No permission for Tier 2 or higher actions."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Build validation-only auth/session/device/profile-binding assessment records against this fixture, if Builder is later delegated.",
      "Do not generate tokens, create sessions, store secrets, start a server, write a queue, perform network work, register devices, mutate role discovery, or execute local actions.",
      "Represent commit 3904697 as the Phase 15 baseline and preserve identity/signing as validation-only.",
      "Emit auth_binding, scope_rules, token_envelope, authorization_boundary, profile_mismatch_handling, verification_report_contract, revocation_expiry_rules, no_secret_no_raw_guarantees, migration_path, gate summary, blocker summary, evidence refs, and side-effect truth sections.",
      "Use token_id/hash placeholders only; no raw token or session secret may appear in output.",
      "Allow only Architect as the server-originated role and require role discovery proof plus target proof before future local acceptance can even be proposed.",
      "Treat valid auth as permission to validate server-to-local proposals/intents only, never as authorization for execution or Tier 2+ actions."
    ],
    "hardRejects": [
      "Any server process, network request/listener, database/store write, queue write, auth/secret/token/session generation, device registry mutation, role-discovery mutation, local execution, shell/PTY, browser/window access, send, customer send, deploy, trade, financial action, file mutation, durable migration, or memory/profile commit occurs.",
      "Any fixture or validation output contains raw tokens, session secrets, auth secrets, credential-like material, raw profile content, raw comms, raw terminal, screenshot/OCR, browser state, customer private data, side-profile content, or raw database payload.",
      "A missing, expired, revoked, stale, replayed, unknown-profile, unknown-device, wrong-session, wrong-device, wrong-profile, side-profile, wrong-role, no-role-proof, or no-target-proof binding is accepted.",
      "Valid auth is treated as authorization for local execution, shell/PTY, Builder/Oracle direct targeting, Tier 2+ work, customer sends, deploys, trades, memory/profile commits, bridge green, or model-processing proof.",
      "Profile mismatch handling exposes raw side-profile content or raw mismatch payloads instead of redacted reason codes.",
      "Phase 16 migration language implies that real auth exists before secret storage policy, session lifecycle, device registry, role discovery proof, deletion/export retention, and audit logging gates are reviewed."
    ]
  },
