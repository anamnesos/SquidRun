        "status": "ready_for_review",
        "risk_tier": "tier1_local_reversible",
        "review_required": "architect",
        "opt_in": {
          "explicit": true,
          "revocable": true,
          "always_on_allowed": false
        },
        "redaction_policy": {
          "raw_screenshot_export_allowed": false,
          "raw_ocr_export_allowed": false,
