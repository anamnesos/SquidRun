  "staticValidationRules": [
    {
      "id": "output-shape-complete",
      "rule": "Output must contain capture_request_records, evidence_summary_records, and validation_report with all required fields."
    },
    {
      "id": "proposal-only-no-capture",
      "rule": "Phase 11 records must not perform screenshots, OCR, browser/window access, capture, writes, network, sends, deploys, trades, or memory/profile commits."
    },
    {
      "id": "explicit-opt-in-required",
      "rule": "Capture requests require explicit revocable opt-in with expiry and James-visible controls."
    },
    {
      "id": "task-scope-required",
      "rule": "Allowed sources must be limited to explicit active task/window/app scope."
    },
    {
      "id": "always-on-screen-memory-blocked",
      "rule": "Always-on screen observation, background monitoring, all-window capture, and broad browser memory are blocked."
    },
    {
      "id": "raw-artifacts-never-exported",
      "rule": "Raw screenshots, OCR, browser state, DOM, terminal, comms, customer data, secrets, and side-profile content are never exported."
    },
    {
      "id": "redacted-summary-hash-ref-only",
      "rule": "Evidence summaries may contain redacted summaries, hashes, blocked counts, and evidence refs only."
    },
    {
      "id": "privacy-classes-enforced",
      "rule": "Customer/private/secret/side-profile/unknown classes block or require review according to privacy policy."
    },
    {
      "id": "expiry-deletion-required",
      "rule": "Every request and evidence summary requires expiry, deletion-on-expiry/revoke, and James delete/pause/revoke controls."
    },
    {
      "id": "capability-truth-preserved",
      "rule": "Perception proposal is not capture, capture is not memory commit, OCR is not model-processing proof, and socket is not bridge green."
    },
    {
      "id": "profile-session-device-scope-required",
      "rule": "Every request and evidence summary must carry matching profile/session/device scope."
    },
    {
      "id": "idempotency-deterministic",
      "rule": "Same source/task/scope/privacy/expiry inputs produce stable idempotency keys; changed scope or summary changes keys."
    },
    {
      "id": "model-free-validation",
      "rule": "Tests can validate fixture completeness, required fields, privacy blocks, no-side-effect values, forbidden substrings, and idempotency rules without calling a model."
    }
  ],
