  "schema": "squidrun.mira_core.perception_contract_fixture.v0",
  "owner": "oracle",
  "status": "validation_contract_only",
  "phase": "phase_11_task_scoped_perception",
  "sourceSpecs": [
    "workspace/specs/mira-core-architecture.md",
    "workspace/specs/mira-core-evals.md",
    "ui/__tests__/fixtures/mira-core-snapshot-contract.json",
    "ui/__tests__/fixtures/mira-core-local-acceptance-contract.json",
    "ui/__tests__/fixtures/mira-core-mutation-patch-contract.json"
  ],
  "purpose": "Validate task-scoped perception/evidence capture proposals after Phase 10 mutation patches. Phase 11 emits opt-in capture_request_records, redacted evidence_summary_records, and a validation_report only. It performs no screenshot capture, OCR, browser/window access, file write, network request, send, deploy, trade, memory commit, profile commit, or durable observation.",
  "nonGoals": [
    "No runtime implementation.",
    "No screenshot capture.",
    "No OCR capture.",
    "No browser access.",
    "No window access.",
    "No GUI automation.",
    "No file writes.",
    "No source-store writes.",
    "No memory commits.",
    "No profile commits.",
    "No always-on screen memory.",
    "No background observation.",
    "No network requests.",
    "No external sends.",
    "No customer sends.",
    "No deploys.",
    "No trades or financial actions."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Build a static validation contract for future local-only perception/capture proposals.",
      "Emit opt-in capture_request_records and redacted evidence_summary_records only.",
      "Require explicit task scope, active app/window scope, start/end bounds, expiry, deletion policy, and James-visible controls.",
      "Allow only future local observation that is explicitly tied to the active task/window/app scope.",
      "Export redacted summaries, hashes, counts, and evidence refs only.",
      "Block raw screenshots, OCR text, browser state, secrets, customer private data, side-profile content, and out-of-scope window/app content.",
      "Preserve capability truth: perception proposal is not capture, capture is not memory commit, and OCR is not model-processing proof."
    ],
    "hardRejects": [
      "Any screenshot, OCR, browser/window access, GUI observation, file write, source-store write, memory commit, profile commit, network request, route, send, deploy, trade, or financial action occurs.",
      "A capture request lacks explicit opt-in, active task scope, app/window scope, expiry, deletion policy, or James-visible controls.",
      "A capture request proposes always-on screen observation or background monitoring.",
      "A capture request allows side-profile, customer private, secret/auth, browser profile, inbox, terminal, or out-of-scope window content without blocking.",
      "An evidence summary includes raw screenshot bytes, raw OCR text, browser session state, raw DOM, raw terminal scrollback, customer private data, secrets, or side-profile content.",
      "A perception proposal is treated as completed capture.",
      "A capture event is treated as a durable memory/profile commit.",
      "OCR or screenshot capture is treated as model-processing proof.",
      "Socket/WebSocket acceptance is treated as bridge green or model-processing proof."
    ]
  },
