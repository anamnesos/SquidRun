    {
      "id": "ready-active-task-window-request",
      "focus": "explicit task-scoped capture request can be ready for review without capture",
      "inputSignals": {
        "request": {
          "opt_in": "explicit",
          "task_id": "task-trustquote-invoice-preview",
          "allowed_app": "TrustQuote",
          "allowed_window_title_pattern": "TrustQuote - Invoice Preview",
          "allowed_source_type": "active_task_window",
          "privacy_classification": "project_internal"
