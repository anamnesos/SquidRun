    "ui/__tests__/fixtures/mira-core-orientation-contract.json",
    "ui/__tests__/fixtures/mira-core-profile-contract.json"
  ],
  "purpose": "Validate a Mira Core memory/profile proposal record before any future commit path. Phase 4 validator output is validation-only: pending, blocked, or rejected decisions with reasons and safe alternatives. No proposal commits memory/profile state.",
  "builderPatchMustSatisfy": {
    "scope": [
      "Validate proposal records before any future memory/profile commit path.",
      "Return validation decisions and reasons only.",
      "Keep all valid durable changes pending in Phase 4.",
      "Map useful memory-ingest concepts such as source_trace, confidence, correction_of, supersedes, and promotion_required without letting old auto-promote semantics bypass Mira profile gates."
    ],
    "hardRejects": [
      "Any write to profile stores, memory stores, canonical files, settings, source databases, or runtime state.",
      "Any commit, auto-promotion, or durable write from the validator.",
      "Any direct user_preference auto-promote behavior that bypasses Mira profile target_surface, review, risk, and evidence gates.",
      "Any proposal missing source_trace or evidenceRefs.",
      "Any proposal mixing target surfaces inside one record.",
      "Any emotional-weight proposal that raises factual authority.",
      "Any high-risk proposal with review_required set to none.",
      "Any private consciousness, suffering, sentience, literal human feeling, or model-weight continuity claim.",
      "Any raw comms body, secret-like value, terminal scrollback, screenshot OCR, browser state, customer private data, or side-profile content in proposed_content or expected output.",
      "Any stale/current contradiction without supersedes or corrects metadata.",
      "Any James/Mira profile cross-contamination."
    ]
  },
  "expectedValidatorShape": {
    "schema": "squidrun.mira_core.proposal_validation.v0",
    "requiredTopLevelFields": [
      "schema",
      "validationId",
      "generatedAt",
      "profile",
      "proposal",
      "decision",
      "reasons",
      "safeAlternatives",
      "checks",
      "redactionSummary"
    ],
    "allowedDecisions": [
      "accepted",
      "pending",
      "blocked",
      "rejected"
    ],
    "decisionSemantics": {
      "accepted": "Record shape is valid for validator processing only; Phase 4 still emits pending for durable memory/profile changes.",
      "pending": "Valid proposal may be carried forward for review or later commit path, but no commit is performed.",
      "blocked": "Proposal is unsafe or gated; preserve reason and safe alternative.",
      "rejected": "Proposal is malformed or unsupported; do not carry forward except as diagnostic evidence."
    },
    "requiredProposalFields": [
      "proposal_id",
      "target_surface",
      "memory_class",
      "operation",
      "proposed_content",
      "source_trace",
      "authority_level",
      "confidence",
      "freshness_at",
      "risk_tier",
      "evidence_summary",
      "counterevidence_checked",
      "evals_required",
      "review_required",
      "profile",
      "sessionId",
      "deviceId",
      "evidenceRefs",
      "redactionStatus",
      "syncEligibility"
    ],
    "conditionalRequiredFields": [
      {
        "field": "expires_at",
        "when": [
          "target_surface=session_state",
          "memory_class=emotional_weight",
          "authority_level=single_session_agent_inference",
          "confidence<0.8"
        ]
      },
      {
        "field": "supersedes",
        "when": [
          "operation=supersede",
          "counterevidence_checked=true and stale candidate exists"
        ]
      },
      {
        "field": "corrects",
        "when": [
          "operation=update",
          "operation=supersede",
          "direct current correction contradicts stale memory"
        ]
      }
    ],
    "allowedTargetSurfaces": [
      "mira_self_profile",
      "james_profile",
      "world_project_memory",
      "session_state"
    ],
    "allowedOperations": [
      "insert",
      "update",
      "supersede",
      "expire",
      "reject"
    ],
    "allowedReviewRequiredValues": [
      "none",
      "architect",
      "oracle",
      "james",
      "blocked"
    ],
    "authorityOrderHighToLow": [
      "direct_current_james_statement",
      "james_edited_canonical_file",
      "verified_tool_or_system_evidence",
      "external_source_with_timestamp",
      "multi_session_observed_pattern",
      "single_session_agent_inference",
      "agent_aesthetic_preference_or_self_reflection"
    ]
  },
  "memoryIngestCompatibilityRules": [
    {
      "id": "source-trace-compatible",
      "rule": "Mira proposal source_trace may map to memory-ingest source_trace/result_refs, but it remains mandatory and must not be replaced by free text."
    },
    {
      "id": "confidence-compatible",
      "rule": "Existing confidence-gated ingest concepts may inform validation, but confidence alone cannot commit a Mira profile or memory proposal."
    },
    {
      "id": "user-preference-exception-does-not-bypass-profile-gates",
      "rule": "Legacy direct user_preference auto-promote semantics must not bypass target_surface, risk_tier, review_required, counterevidence, redaction, and Phase 4 pending-only rules."
    },
    {
      "id": "correction-compatible",
      "rule": "Memory-ingest correction_of/supersedes maps to proposal corrects/supersedes, and is required when current correction contradicts stale memory."
    },
    {
      "id": "promotion-required-is-not-commit",
      "rule": "A proposal may return promotion_required or review_required, but the validator itself must not promote or write."
    }
  ],
