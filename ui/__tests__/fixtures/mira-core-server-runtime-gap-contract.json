  "baseline": {
    "commit": "785dbec",
    "commit_subject": "Add Mira Core Phase 1-13 read-only validation package",
    "baseline_status": "phase_1_13_read_only_validation_package",
    "baseline_boundary": "No real Mira Core server, network receive, database/store write, queue, auth change, local execution, send, deploy, or trade exists at this baseline."
  },
  "sourceSpecs": [
    "workspace/specs/mira-core-architecture.md",
    "workspace/specs/mira-core-evals.md",
    "ui/__tests__/fixtures/mira-core-readiness-contract.json",
