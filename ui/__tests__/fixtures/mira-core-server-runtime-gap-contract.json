  "staticValidationRules": [
    {
      "id": "baseline-commit-pinned",
      "must": "server_runtime_gap_assessment.baseline_commit and validation_report.baseline_commit are exactly 785dbec, the Phase 1-13 baseline commit."
    },
    {
      "id": "phase-14-validation-only",
      "must": "Phase 14 emits a gap assessment and validation report only; it does not start a server, network listener, store write, queue, auth change, local execution, send, deploy, trade, or durable migration."
    },
    {
      "id": "server-identity-required-before-receive",
      "must": "Future receive is blocked until server instance identity, public key ref, issuer, audience, key rotation, revocation, and private-key non-export rules are specified."
    },
    {
      "id": "signing-envelope-required-before-receive",
      "must": "Future receive is blocked unless canonical signing covers profile, session, device, idempotency key, nonce, timestamp, watermarks, and redaction audit."
    },
    {
      "id": "auth-session-device-profile-binding-required",
      "must": "Future server auth binds subject, session, device, profile, scopes, token audience, and expiry; profile/session/device mismatches and side-profile access are rejected."
    },
    {
      "id": "redacted-receive-store-eligibility-only",
      "must": "Future store eligibility is limited to core_sync_safe and already-redacted core_sync_redacted items with required metadata, redaction audit, signature verification, and auth binding."
    },
    {
      "id": "raw-private-content-blocked",
      "must": "Raw comms, raw terminal, screenshot/OCR, browser state, secrets/auth, customer private data, side-profile content, and raw database payload are forbidden in assessment, reports, and future receive/store records."
    },
    {
      "id": "deletion-export-retention-controls-required",
      "must": "Future server storage is blocked until deletion, export, retention, tombstone, audit, idempotency, scope binding, and James-visible controls are specified."
    },
    {
      "id": "replay-idempotency-watermark-rules-required",
      "must": "Future receive is blocked until replay cache, nonce rejection, watermark regression rejection, stale handling, content hash, redaction policy hash, and scope hash rules are specified."
    },
    {
      "id": "offline-local-arms-truth-preserved",
      "must": "Future server status may report local arms offline or unknown, but cannot claim local execution, PTY, shell, browser/window access, or model-processing proof."
    },
    {
      "id": "server-to-local-intents-architect-only",
      "must": "Future server-originated intents target Architect only, allow Tier 0/Tier 1 only, require local acceptance, and block direct Builder/Oracle targets."
    },
