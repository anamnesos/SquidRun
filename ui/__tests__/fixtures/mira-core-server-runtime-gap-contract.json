    "ui/__tests__/fixtures/mira-core-local-acceptance-contract.json",
    "ui/__tests__/fixtures/mira-core-server-boundary-contract.json"
  ],
  "purpose": "Define the validation-only gap contract that must be satisfied before any real Mira Core server runtime can exist after the Phase 1-13 baseline. Phase 14 is not a server implementation. It specifies preconditions, record shapes, gates, forbidden claims, and side-effect truth for future server identity, signing, auth binding, redacted receive/store, deletion/export/retention, replay/idempotency/watermarks, offline local-arms truth, and server-to-local intent limits.",
  "nonGoals": [
    "No runtime implementation.",
    "No server process.",
    "No network listener or network request.",
    "No database or source-store write.",
    "No queue creation or enqueue.",
    "No auth, secret, signing key, token, credential, or session generation.",
    "No local execution.",
    "No shell or PTY action.",
    "No browser, window, screenshot, or OCR access.",
    "No external sends or customer sends.",
    "No deploys.",
    "No trades or financial actions.",
    "No claim that socket connection proves bridge green.",
    "No claim that delivery acceptance proves recipient model processing.",
    "No migration from validation-only data into durable server state."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Build validation-only server-runtime gap assessment records against this fixture, if Builder is later delegated.",
      "Do not create a server runtime or any side-effecting path.",
      "Represent commit 785dbec as the Phase 1-13 baseline and preserve its validation-only boundaries.",
      "Define preflight gates for future server identity, signing, auth/session/device/profile binding, redacted receive/store eligibility, deletion/export/retention, replay/idempotency/watermarks, offline local-arms status, server-to-local intents, bridge/delivery proof, and migration.",
      "Every future-real-server section must include status, required fields, blocking gaps, evidence refs, and explicit not_implemented_now truth.",
      "Only Tier 0/Tier 1 server-to-local intents to local Architect may be considered for future local acceptance, and only after local acceptance.",
      "Any real server work remains blocked until identity/signing/auth/storage/deletion/retention/replay contracts and tests are reviewed."
    ],
    "hardRejects": [
      "Any server process, network request/listener, database/store write, queue, auth/secret/signing material generation, local execution, shell/PTY, browser/window access, send, customer send, deploy, trade, financial action, file mutation, or durable migration occurs.",
      "A future server record accepts raw comms, raw terminal, screenshot/OCR, browser state, secrets/auth material, customer private data, side-profile content, or raw database payload.",
      "A future server stores blocked, local_only, approval_required, unredacted core_sync_redacted, stale, watermark-regressed, profile-mismatched, session-mismatched, device-mismatched, unsigned, or unauthenticated upload items.",
      "A future server accepts Tier 2, Tier 3, Tier 4, identity-core rewrite, auth/secrets, deploy, customer-send, financial, local-execution, Builder-targeted, or Oracle-targeted intent as pending local acceptance.",
      "A future server claims local execution, PTY, shell, browser/window access, customer send, deploy, trade, financial action, bridge green from socket alone, or model-processing proof from delivery acceptance.",
      "A migration path treats Phase 1-13 validation-only artifacts as durable server truth without new identity, signing, auth, redaction, deletion/export/retention, replay, and review gates."
    ]
  },
