{
  "schema": "squidrun.mira.progress_contract.v0",
  "version": 1,
  "status": "accepted_v0_machine_readable_contract",
  "accepted_source_refs": [
    "oracle#17",
    "architect#53"
  ],
  "definition_100": "Mira is a durable, evidence-bound product surface that keeps presence, restart continuity, command context, team coordination, direct reachability, voice transport, and tool/action planning current across restarts without James restating the premise or the team inventing progress.",
  "formula": {
    "aggregate": "weighted_sum_of_category_computed_percent",
    "weight_total": 100,
    "manual_bumps_allowed": false,
    "missing_proof_policy": "unknown_zero_score",
    "stale_source_policy": "warn_and_apply_contract_caps",
    "historical_estimate_excluded_from_computation": true
  },
  "historical_baseline": {
    "kind": "historical_conversational_estimate",
    "label": "35-45% real",
    "range": {
      "min": 35,
      "max": 45
    },
    "nominal": 40,
    "source_refs": [
      "architect#43",
      "architect#48"
    ],
    "computed_authority": false
  },
  "anti_drift": {
    "no_durable_global_percent_field": true,
    "number_update_requires_source_evidence": true,
    "number_update_requires_reason": true,
    "computed_value_wins_over_historical_estimate": true,
    "allowed_input_kinds": [
      "progress_contract_fixture",
      "presence_runtime_state_json",
      "test_or_probe_proof_input",
      "blocked_status_flags",
      "git_head_metadata"
    ]
  },
  "categories": [
    {
