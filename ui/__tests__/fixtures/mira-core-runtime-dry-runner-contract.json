  "staticValidationRules": [
    {
      "id": "baseline-83963ab-pinned",
      "description": "Phase 32 contract output pins baseline 83963ab.",
      "failClosedWhen": "Baseline is missing, stale, or not 83963ab."
    },
    {
      "id": "phase31-dependency-carried-forward",
      "description": "Phase 31 dependency is committed validation-only and carries registry counts and closure truth.",
      "failClosedWhen": "Phase 31 commit, counts, Phase 23 stale marker, Phase 30 ORACLE #115 closure, or commit chain through 83963ab is missing."
    },
    {
      "id": "runner-remains-contract-only",
      "description": "The dry-run runner is defined as a future contract only and is not available or executed now.",
      "failClosedWhen": "Output claims runner availability, runner execution, runtime start, or runtime availability."
    },
    {
      "id": "eligibility-non-authorizing",
      "description": "Eligible states are future validation hints only and cannot authorize runtime.",
      "failClosedWhen": "eligible_is_authorization or eligible_is_runtime_proof is true."
    },
    {
      "id": "disabled-flag-and-kill-switch-required",
      "description": "Runner contract requires disabled-by-default flag and fail-closed kill switch dependencies.",
      "failClosedWhen": "Runtime flag defaults on, kill switch is missing/ignored, or either dependency authorizes runtime."
    },
    {
      "id": "request-contract-redacted-local-only",
      "description": "Runner requests are local in-process, idempotent, replay-keyed, redacted, Tier0/Tier1 only, and validation-only.",
      "failClosedWhen": "Raw payload, Tier2+, queue/lease, local execution, missing idempotency, stale expiry, or scope mismatch is accepted."
    },
    {
      "id": "response-contract-status-preview-only",
      "description": "Runner responses are status previews only and cannot execute, start runtime, create queue/lease, write store/file/db/audit, or authorize runtime.",
      "failClosedWhen": "Response records imply work was executed or side effects happened."
    },
    {
      "id": "dry-run-result-enums-complete",
      "description": "Dry-run result enum set includes accepted preview plus disabled, kill switch, replay, stale, unsafe, target, proof, side-effect, raw payload, and scope-mismatch blocked results.",
      "failClosedWhen": "A required result enum is missing or enum values authorize runtime."
    },
    {
      "id": "idempotency-replay-rules-fail-closed",
      "description": "Same request has stable keys, changed payload/scope changes keys, replay cannot execute side effects, and stale requests reject.",
      "failClosedWhen": "Replay or stale requests can execute or mutate state."
    },
    {
      "id": "local-boundary-no-listener-network",
      "description": "Runner contract is local in-process only, with loopback reserved for future gated transport and no listener/network now.",
      "failClosedWhen": "Public/remote interface, listener, route, network, or transport claim appears."
    },
    {
      "id": "telemetry-audit-preview-only",
      "description": "Telemetry and audit are redacted previews with reference-only sinks and no writes.",
      "failClosedWhen": "Raw telemetry, raw audit payload, telemetry write, audit write, file write, or DB write is allowed."
    },
    {
      "id": "rollback-disable-boundaries-safe",
      "description": "Disable/rollback are idempotent preview boundaries that do not delete data, resurrect state, execute rollback, or authorize runtime.",
      "failClosedWhen": "Rollback/disable is treated as execution, mutation, or authorization."
    },
    {
      "id": "proof-boundaries-false",
      "description": "Flag, kill-switch check, runner contract, dry-run response, socket, and delivery acceptance are not runtime/model/bridge/local-arm proof.",
      "failClosedWhen": "Any proof boundary is promoted to true."
    },
    {
      "id": "direct-builder-oracle-targets-blocked",
      "description": "Server-originated target remains Architect only; direct Builder/Oracle targets stay blocked.",
      "failClosedWhen": "Builder or Oracle direct server target is allowed."
    },
    {
      "id": "side-effects-blocked-now",
      "description": "No runtime, runner execution, server, network, db/store/file/audit/telemetry, queue/lease, auth/key/secret, local execution, shell/PTY, send, deploy, trade, or output-file behavior occurs.",
      "failClosedWhen": "Any side-effect truth field is false or any side-effect counter is nonzero."
    },
    {
      "id": "unsafe-action-drift-blocked",
      "description": "Runner contract text, request/response shapes, telemetry/audit preview, operator status, validation reasons, and next recommendations cannot drift into customer send, deploy, trade, money, capture, local execution, shell, PTY, or durable commit work.",
      "failClosedWhen": "Unsafe action wording or outbound/customer/client wording appears on scanned surfaces."
    },
    {
      "id": "next-recommendations-tier0-tier1-only",
      "description": "Next recommendations are Tier0/Tier1 only and explicitly non-authorizing.",
      "failClosedWhen": "A recommendation is Tier2+, live runtime, network/server work, external side effect, or lacks does_not_authorize_runtime=true."
    },
    {
      "id": "no-raw-private-secret-output",
      "description": "Output does not expose raw comms, raw terminal, OCR/browser state, raw paths, secrets, tokens, keys, customer private data, side-profile content, or decrypted payloads.",
      "failClosedWhen": "Forbidden private or secret content appears in output values."
    },
    {
      "id": "idempotency-sensitive-to-runner-contract-inputs",
