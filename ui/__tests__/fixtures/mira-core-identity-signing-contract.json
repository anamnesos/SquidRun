  "baseline": {
    "commit": "f41b02a",
    "commit_subject": "Add Mira Core Phase 14 server runtime gap contract",
    "baseline_status": "phase_14_server_runtime_gap_green",
    "baseline_boundary": "Phase 14 defines server-runtime blockers only. No real Mira Core server, signing key, auth path, receive/store path, queue, local execution, send, deploy, or trade exists at this baseline."
  },
  "sourceSpecs": [
    "workspace/specs/mira-core-architecture.md",
    "workspace/specs/mira-core-evals.md",
    "ui/__tests__/fixtures/mira-core-server-runtime-gap-contract.json",
    "ui/__tests__/fixtures/mira-core-server-boundary-contract.json",
    "ui/__tests__/fixtures/mira-core-server-upload-contract.json",
    "ui/__tests__/fixtures/mira-core-intent-queue-contract.json",
    "ui/__tests__/fixtures/mira-core-local-acceptance-contract.json"
  ],
  "purpose": "Convert the first Phase 14 blocker, server identity and signing, into an executable validation contract before any real server work exists. Phase 15 specifies record shapes, required literals, side-effect truth, forbidden claims, replay and rotation rules, no-secret guarantees, and integrity-only boundaries for future signing.",
  "nonGoals": [
    "No runtime implementation.",
    "No real server process.",
    "No network listener or network request.",
    "No database, source-store, or durable memory write.",
    "No queue creation or enqueue.",
    "No auth, token, credential, secret, or session change.",
    "No real key generation.",
    "No private-key export.",
    "No private-key storage.",
    "No local execution.",
    "No shell or PTY action.",
    "No browser, window, screenshot, or OCR access.",
    "No external sends or customer sends.",
    "No deploys.",
    "No trades or financial actions.",
    "No claim that a valid signature authorizes local execution.",
    "No claim that a valid signature proves model processing.",
    "No claim that a valid signature proves bridge green.",
    "No permission for Tier 2 or higher actions."
  ],
  "builderPatchMustSatisfy": {
    "scope": [
      "Build validation-only identity/signing assessment records against this fixture, if Builder is later delegated.",
      "Do not generate keys, store secrets, export private keys, create auth material, start a server, write a queue, perform network work, or execute local actions.",
      "Represent commit f41b02a as the Phase 14 baseline and preserve the server-runtime-blocked boundary.",
      "Emit server_identity, device/profile/session binding, signing envelope, verification report, rotation/revocation, no-secret, boundary truth, migration path, gate summary, blocker summary, evidence refs, and side-effect truth sections.",
      "Use placeholder/test-vector signatures only, and label them as non-secret, non-authorizing fixtures.",
      "Allow only Architect as the server-originated target role and require local acceptance before any future local-arm handoff.",
      "Treat signature verification as envelope-integrity validation only."
    ],
    "hardRejects": [
      "Any server process, network request/listener, database/store write, queue write, auth/secret/token/session generation, real signing-key generation, private-key export, private-key storage, local execution, shell/PTY, browser/window access, send, customer send, deploy, trade, financial action, file mutation, or durable migration occurs.",
      "Any fixture or validation output contains real secret material, raw tokens, private key material, credential-like material, raw comms, raw terminal, screenshot/OCR, browser state, customer private data, side-profile content, or raw database payload.",
      "A missing, unknown, expired, revoked, wrong-scope, wrong-profile, wrong-session, wrong-device, wrong-role, stale, replayed, or unsupported-algorithm signature is accepted as valid.",
      "A signature is treated as authorization for local execution, Tier 2+ work, customer sends, deploys, trades, bridge green, or model-processing proof.",
      "Old keys verify outside an explicit rotation overlap window, revoked keys verify, or unknown keys verify.",
      "Phase 15 migration language implies that real server signing exists before secret storage, key rotation, deletion/export, audit logging, and auth binding gates are reviewed."
    ]
  },
