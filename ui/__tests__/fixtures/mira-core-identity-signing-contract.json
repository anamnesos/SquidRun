  "staticValidationRules": [
    {
      "id": "phase-15-baseline-f41b02a-pinned",
      "must": "identity_signing_assessment.baseline_commit and validation_report.baseline_commit are exactly f41b02a, the Phase 14 server-runtime-gap baseline."
    },
    {
      "id": "validation-only-no-real-signing",
      "must": "Phase 15 emits validation records only; it does not start a server, perform network work, write stores or queues, generate keys, create auth material, export or store private keys, execute locally, send, deploy, trade, or migrate durable state."
    },
    {
      "id": "server-identity-shape-required",
      "must": "server_identity includes server_id, environment, key_id, public_key_fingerprint, issuer, created_at, rotated_at, revoked_at, and status."
    },
    {
      "id": "device-profile-session-binding-required",
      "must": "device/profile/session binding includes device_id, profile, session_id, allowed_target_role=architect, tenant/user boundary, freshness, and rejects cross-profile, side-profile, stale, wrong-device, wrong-session, and wrong-role inputs."
    },
    {
      "id": "canonical-envelope-shape-required",
      "must": "signing_envelope includes payload_hash, canonicalization_version, allowlisted signature_algorithm, key_id, nonce, timestamp, expires_at, replay_window_ms, and a placeholder/test-vector signature only."
    },
    {
      "id": "signature-algorithm-allowlist-required",
      "must": "Only fixture-declared test-vector algorithms are accepted in v0; unknown or production-looking algorithms are blocked until real key management exists."
    },
    {
      "id": "verification-report-shape-required",
      "must": "verification report supports accepted, pending, blocked, and rejected decisions with reasons, evidenceRefs, replay/idempotency result, key status, and clock skew/freshness result."
    },
    {
      "id": "replay-idempotency-freshness-required",
      "must": "Nonce reuse, expired envelopes, future timestamps, stale bindings, and idempotency drift are rejected; duplicate payload and scope returns the same decision."
    },
    {
      "id": "rotation-revocation-rules-required",
      "must": "Old keys verify only within explicit overlap, revoked keys are blocked, unknown keys are blocked, and rotation/revocation events require audit evidence refs."
    },
    {
      "id": "no-secret-guarantees-required",
