{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mira.normalized_core_approval_marker.v0",
  "type": "object",
  "required": [
    "schema",
    "approval_id",
    "approved_at",
    "approved_by",
    "batch_id",
    "report_id",
    "report_path",
    "contract_path",
    "approved_record_ids",
    "approval_scope",
    "caveats_preserved",
    "mutation_limits"
  ],
  "properties": {
    "schema": {
      "const": "mira.normalized_core_approval_marker.v0"
    },
    "approval_id": {
      "type": "string"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_by": {
      "enum": [
        "architect",
        "james"
      ]
    },
    "batch_id": {
      "const": "normalized-core-state-v1"
    },
    "report_id": {
      "const": "batch-2a-normalized-core-dry-run-v1"
    },
    "report_path": {
      "const": "mira/imports/reports/batch-2a-normalized-core-dry-run-v1.json"
    },
    "contract_path": {
      "const": "mira/imports/normalizers/batch-2a-core-normalizer-contract-v0.json"
    },
    "approved_record_ids": {
      "type": "array",
      "prefixItems": [
        {
          "const": "mira_self_profile"
        },
        {
          "const": "james_relationship_state"
        },
        {
          "const": "relationship_presence_permissions"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "approval_scope": {
      "const": "normalized_preview_and_apply_design_only"
    },
    "caveats_preserved": {
      "type": "object",
      "required": [
        "local_store_write_allowed_now_scoped",
        "stale_session_window_device_metadata_only",
        "current_focus_demoted_to_source_focus_summary",
        "growth_events_excluded"
      ],
      "properties": {
        "local_store_write_allowed_now_scoped": {
          "const": true
        },
        "stale_session_window_device_metadata_only": {
          "const": true
        },
        "current_focus_demoted_to_source_focus_summary": {
          "const": true
        },
        "growth_events_excluded": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "mutation_limits": {
      "type": "object",
      "required": [
        "normalizer_execution_allowed",
        "apply_design_allowed",
        "state_write_allowed",
        "receipt_write_allowed",
        "queue_mutation_allowed",
        "report_mutation_allowed",
        "runtime_load_allowed",
        "raw_import_allowed"
      ],
      "properties": {
        "normalizer_execution_allowed": {
          "const": true
        },
        "apply_design_allowed": {
          "const": true
        },
        "state_write_allowed": {
          "const": false
        },
        "receipt_write_allowed": {
          "const": false
        },
        "queue_mutation_allowed": {
          "const": false
        },
        "report_mutation_allowed": {
          "const": false
        },
        "runtime_load_allowed": {
          "const": false
        },
        "raw_import_allowed": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
