{
  "name": "mira-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mira-owned local runtime service scaffold.",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "status": "node dist/status.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}
